{
  "expo": {
    "name": "Mercadito",
    "slug": "mercadito",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mercadito",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF7EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mx.mercadito.app"
    },
    "android": {
      "package": "mx.mercadito.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF7EB"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#FF7A2B",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "La app usa tus fotos para subir imagen del producto o logo.",
          "cameraPermission": "La app usa la cámara para tomar foto del producto."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "La app usa tu ubicación para marcar dónde está tu tienda."
        }
      ]
    ],
    "notification": {
      "color": "#FF7A2B",
      "androidMode": "default",
      "androidCollapsedTitle": "Mercadito"
    },
    "extra": {
      "apiBaseUrl": "https://mercadito.cx",
      "router": {},
      "eas": {
        "projectId": "715af47b-899d-4651-9731-29f6ebc24516"
      }
    },
    "owner": "jadhasfuh"
  }
}
