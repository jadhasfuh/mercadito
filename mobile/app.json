{
  "expo": {
    "name": "Mercadito",
    "slug": "mercadito",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "mercadito",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FFF7EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mx.mercadito.app"
    },
    "android": {
      "package": "mx.mercadito.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFF7EB"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "https://mercadito.cx"
    }
  }
}
